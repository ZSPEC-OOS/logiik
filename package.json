{
  "name": "spawn-ai",
  "version": "1.0.0",
  "description": "SPAWN - Synthetic Programming Agent with Operational Network",
  "type": "module",
  "main": "dist/core/agent.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/core/agent.ts",
    "start": "node dist/core/agent.js",
    "spawn:init": "node dist/core/init.js",
    "spawn:start": "node dist/core/agent.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "coding-assistant",
    "code-generation",
    "agent",
    "llm",
    "autonomous"
  ],
  "author": "SPAWN Team",
  "license": "MIT",
  "dependencies": {
    "@babel/parser": "^7.23.0",
    "@babel/traverse": "^7.23.0",
    "@babel/types": "^7.23.0",
    "@typescript-eslint/typescript-estree": "^6.0.0",
    "chalk": "^5.3.0",
    "commander": "^11.0.0",
    "dotenv": "^16.3.0",
    "fast-glob": "^3.3.0",
    "ignore": "^5.3.0",
    "minimatch": "^9.0.0",
    "ollama": "^0.4.0",
    "openai": "^4.20.0",
    "ora": "^7.0.0",
    "semver": "^7.5.0",
    "simple-git": "^3.20.0",
    "yaml": "^2.3.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.0",
    "@types/node": "^20.0.0",
    "@types/semver": "^7.5.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitest/ui": "^1.0.0",
    "eslint": "^8.50.0",
    "tsx": "^4.0.0",
    "typescript": "^5.2.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
