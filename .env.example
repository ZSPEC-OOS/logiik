# ─── Logiik Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# Pinecone
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_HOST=https://logiik-knowledge-epzvgby.svc.aped-4627-b74a.pinecone.io
PINECONE_INDEX=logiik-knowledge

# Firebase
FIREBASE_PROJECT=nero-85ed0
FIREBASE_API_KEY=your_firebase_api_key_here

# Redis (disabled until configured)
REDIS_HOST=your_redis_host_here
REDIS_PASSWORD=your_redis_password_here

# AWS S3 (disabled until configured)
S3_BUCKET_KNOWLEDGE=your_bucket_name_here
S3_BUCKET_MODELS=your_model_bucket_name_here
S3_MODEL_KEY=logiik_model/latest.pt
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_key_here
AWS_SECRET_ACCESS_KEY=your_secret_here
