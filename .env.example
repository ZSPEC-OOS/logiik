# Teacher AI API Key (OpenAI or Anthropic)
TEACHER_API_KEY=your-api-key-here

# Teacher provider: openai or anthropic
TEACHER_PROVIDER=openai

# Local brain storage path (weights, checkpoints, vectors)
KNOWLEDGE_BASE_PATH=./knowledge_base

# Firebase cloud memory
# Project ID: Firebase Console → Project Settings → General → Project ID
FIREBASE_PROJECT_ID=your-firebase-project-id
# Web API Key: Firebase Console → Project Settings → General → Web API Key
FIREBASE_WEB_API_KEY=your-firebase-web-api-key

# API server settings
API_HOST=0.0.0.0
API_PORT=8000
